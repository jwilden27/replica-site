---
import { content } from "../data/types";
const { header, brand } = content;
---
<header class="sticky top-0 z-40 paper-bg/95 backdrop-blur border-b border-[color:var(--shell)]/10" style="background-color: rgba(245, 239, 228, 0.92);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <a href="/" class="display text-2xl tracking-tight" style="color: var(--shell);">{brand.logoText}</a>
    <nav class="hidden md:flex items-center gap-10">
      {header.nav.map((item) => (
        <a href={item.href} class="eyebrow text-xs hover:opacity-60 transition-opacity" style="color: var(--shell);">{item.label}</a>
      ))}
    </nav>
    <a href={header.ctaUrl} class="shell-btn px-5 py-2.5 eyebrow text-xs rounded-full transition-colors">
      {header.ctaLabel}
    </a>
  </div>
</header>
