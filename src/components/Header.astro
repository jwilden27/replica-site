---
import { content } from "../data/types";
const { header, brand } = content;
---
<header class="sticky top-0 z-40 paper-bg border-b" style="border-color: rgba(61, 43, 31, 0.1); background-color: var(--paper);">
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between gap-8">
    <a href="/" class="display text-3xl tracking-tighter flex-shrink-0" style="color: var(--shell);">{brand.logoText}</a>

    <nav class="hidden md:flex items-center gap-10 flex-1 justify-center">
      {header.nav.map((item) => (
        <a href={item.href} class="eyebrow text-xs hover:opacity-60 transition-opacity whitespace-nowrap" style="color: var(--shell);">{item.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-5 flex-shrink-0">
      <button class="hidden md:inline-flex items-center gap-2 eyebrow text-xs hover:opacity-60 transition-opacity" style="color: var(--shell);" aria-label="Search">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7" />
          <path d="m20 20-3.5-3.5" />
        </svg>
        <span class="hidden lg:inline">Search</span>
      </button>
      <a href={header.ctaUrl} class="shell-btn px-6 py-3 eyebrow text-xs rounded transition-colors">{header.ctaLabel}</a>
    </div>
  </div>
</header>
