---
import { content } from "../data/types";
const offer = content.offerBanner;
---
{offer && (
  <div class="shell-2-bg text-center py-3 px-4">
    <a href={offer.ctaUrl} class="inline-flex items-center gap-3 eyebrow text-xs hover:opacity-80 transition-opacity" style="color: var(--paper);">
      {offer.eyebrow && <span style="opacity: 0.6;">{offer.eyebrow}</span>}
      <span class="font-bold">{offer.headline}</span>
      {offer.ctaLabel && <span class="hidden sm:inline" style="opacity: 0.7;">— {offer.ctaLabel} →</span>}
    </a>
  </div>
)}
