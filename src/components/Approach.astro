---
import { content } from "../data/types";
const { approach } = content;
---
<section id="approach" class="py-24 md:py-32 paper-bg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="eyebrow text-xs mb-4 text-center" style="color: var(--shell);">Our Approach</div>
    <h2 class="display text-4xl md:text-6xl text-center mb-20 max-w-3xl mx-auto" style="color: var(--shell);">Built for the way you actually live.</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      {approach.map((p) => (
        <div class="border-t-2 pt-6" style="border-color: var(--shell);">
          <h3 class="display text-lg" style="color: var(--shell);">{p.headline}</h3>
          <p class="mt-3 text-sm leading-relaxed" style="color: rgba(26, 15, 8, 0.7);">{p.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
