---
import { content } from "../data/types";
const { footer, brand } = content;
---
<footer class="shell-2-bg py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 mb-16">
      <div class="col-span-2 md:col-span-1">
        <div class="display text-3xl" style="color: var(--cream);">{brand.logoText}</div>
        <p class="mt-4 text-sm leading-relaxed" style="color: rgba(245, 239, 228, 0.55);">{brand.tagline}</p>
      </div>
      {footer.columns.map((col) => (
        <div>
          <h4 class="eyebrow text-xs" style="color: var(--cream);">{col.title}</h4>
          <ul class="mt-4 space-y-3">
            {col.links.map((l) => (
              <li><a href={l.href} class="text-sm hover:opacity-100 transition-opacity" style="color: rgba(245, 239, 228, 0.7);">{l.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
      <div>
        <h4 class="eyebrow text-xs" style="color: var(--cream);">Contact</h4>
        <ul class="mt-4 space-y-3 text-sm">
          <li><a href={`mailto:${footer.contact.email}`} class="hover:opacity-100 transition-opacity" style="color: rgba(245, 239, 228, 0.7);">{footer.contact.email}</a></li>
          <li><a href={`tel:${footer.contact.phone}`} class="hover:opacity-100 transition-opacity" style="color: rgba(245, 239, 228, 0.7);">{footer.contact.phone}</a></li>
        </ul>
      </div>
    </div>
    <div class="pt-8 flex flex-col md:flex-row justify-between gap-4" style="border-top: 1px solid rgba(217, 199, 167, 0.15);">
      <p class="text-xs" style="color: rgba(245, 239, 228, 0.4);">{footer.copyright}</p>
      <div class="flex gap-6">
        {footer.social.map((s) => (
          <a href={s.url} class="eyebrow text-xs hover:opacity-100 transition-opacity" style="color: rgba(245, 239, 228, 0.7);">{s.platform}</a>
        ))}
      </div>
    </div>
  </div>
</footer>
